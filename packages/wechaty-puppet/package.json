{
  "name": "@cococat/wechaty-puppet",
  "version": "0.11.15",
  "description": "Wechaty Puppet for agent-wechat — bridges Wechaty bots to WeChat via the agent-wechat REST/WebSocket server",
  "type": "module",
  "main": "./dist/mod.js",
  "types": "./dist/mod.d.ts",
  "exports": {
    ".": {
      "import": "./dist/mod.js",
      "types": "./dist/mod.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild src/mod.ts --bundle --format=esm --platform=node --outfile=dist/mod.js --external:wechaty-puppet --external:file-box && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "test:puppet": "node --import tsx scripts/test-puppet.ts",
    "test:contacts": "node --import tsx scripts/test-contacts.ts",
    "test:ding-dong": "node --import tsx scripts/test-ding-dong.ts"
  },
  "peerDependencies": {
    "wechaty-puppet": "^1.10.2"
  },
  "dependencies": {
    "file-box": "^1.4.15"
  },
  "devDependencies": {
    "@cococat/shared": "workspace:*",
    "@types/node": "^22",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5",
    "wechaty-puppet": "^1.20.2"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thisnick/agent-wechat.git",
    "directory": "packages/wechaty-puppet"
  }
}

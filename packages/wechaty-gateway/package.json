{
  "name": "@cococat/wechaty-gateway",
  "version": "0.11.15",
  "private": true,
  "description": "Wechaty gRPC gateway wrapping @cococat/wechaty-puppet",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --format=esm --platform=node --outfile=dist/main.js --packages=external",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cococat/shared": "workspace:*",
    "@cococat/wechaty-puppet": "workspace:*",
    "file-box": "^1.4.15",
    "wechaty-puppet": "^1.20.2",
    "wechaty-puppet-service": "^1.18.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5"
  }
}

#!/bin/bash
# Press key combination, optionally activating a specific window first
# Usage: key <combo>
#        key --window <pid> <wx> <wy> <ww> <wh> -- <combo>
#
# Examples:
#   key Return
#   key ctrl+a
#   key alt+F4
#   key shift+Tab
#   key --window 1234 100 100 800 600 -- ctrl+Tab

set -euo pipefail

# Parse optional --window flag
if [ "${1:-}" = "--window" ]; then
  if [ "$#" -lt 7 ]; then
    echo "Usage: key --window <pid> <wx> <wy> <ww> <wh> -- <combo>" >&2
    exit 1
  fi
  WIN_PID="$2"
  WIN_X="$3"
  WIN_Y="$4"
  WIN_W="$5"
  WIN_H="$6"
  shift 6
  # Skip the -- separator if present
  if [ "${1:-}" = "--" ]; then
    shift
  fi

  # Activate the window first
  SCRIPT_DIR="$(dirname "$0")"
  "$SCRIPT_DIR/window-activate" "$WIN_PID" "$WIN_X" "$WIN_Y" "$WIN_W" "$WIN_H" >/dev/null || {
    echo "Warning: could not activate window" >&2
  }
fi

if [ -z "${1:-}" ]; then
  echo "Usage: key <combo>" >&2
  echo "       key --window <pid> <wx> <wy> <ww> <wh> -- <combo>" >&2
  echo "Examples: Return, ctrl+a, alt+F4, shift+Tab" >&2
  exit 1
fi

COMBO="$1"

xdotool key "$COMBO"
echo "pressed: $COMBO"

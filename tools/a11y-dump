#!/usr/bin/env python3
"""
Dump AT-SPI accessibility tree for WeChat automation.

Usage:
  a11y-dump                    # JSON nested tree (default)
  a11y-dump --format json      # JSON nested tree
  a11y-dump --format aria      # ARIA-style human-readable

Output formats:
  json: Nested tree with children arrays, compatible with CSS selectors
  aria: Playwright-style indented tree for debugging
"""
import argparse
import json
import sys

try:
    import gi
    gi.require_version('Atspi', '2.0')
    from gi.repository import Atspi
except Exception as exc:
    print(json.dumps({"error": f"failed to import atspi: {exc}"}))
    sys.exit(1)


def get_bounds(node):
    """Get element bounds in screen coordinates."""
    try:
        comp = node.get_component_iface()
        if not comp:
            return None
        rect = comp.get_extents(Atspi.CoordType.SCREEN)
        if rect.width <= 0 or rect.height <= 0:
            return None
        return {
            "x": rect.x,
            "y": rect.y,
            "width": rect.width,
            "height": rect.height
        }
    except Exception:
        return None


def get_states(node):
    """Get accessible states as a list of state names."""
    try:
        state_set = node.get_state_set()
        if not state_set:
            return None
        # Get all active states
        states = state_set.get_states()
        if not states:
            return None
        # Convert to readable names using value_name attribute
        # value_name gives "ATSPI_STATE_SELECTED" -> strip prefix and uppercase
        state_names = []
        for s in states:
            name = s.value_name.upper().replace("ATSPI_STATE_", "")
            state_names.append(name)
        # Filter to useful states (skip common ones like ENABLED, SHOWING, VISIBLE)
        useful_states = [s for s in state_names if s in (
            "FOCUSED", "SELECTED", "CHECKED", "PRESSED", "EXPANDED",
            "COLLAPSED", "ACTIVE", "ARMED", "BUSY", "EDITABLE"
        )]
        # Detect disabled state for interactive elements (ENABLED absent)
        role = node.get_role_name().replace(" ", "-")
        interactive_roles = {"push-button", "toggle-button", "check-box", "radio-button",
                             "text", "combo-box", "menu-item", "spin-button"}
        if role in interactive_roles and "ENABLED" not in state_names:
            useful_states.append("DISABLED")
        return useful_states if useful_states else None
    except Exception:
        return None


def get_window_info(node):
    """Get window-related info for frame nodes (PID, attributes)."""
    info = {}
    try:
        # Get process ID - can be used with xdotool search --pid
        pid = node.get_process_id()
        if pid > 0:
            info["pid"] = pid
    except Exception:
        pass

    try:
        # Get accessible ID (AT-SPI internal, not X11 window ID)
        info["id"] = node.get_id()
    except Exception:
        pass

    try:
        # Get attributes - some implementations include window ID here
        attrs = node.get_attributes()
        if attrs:
            # Convert GHashTable to dict
            attr_dict = {}
            for key in attrs.keys():
                attr_dict[key] = attrs[key]
            if attr_dict:
                info["attributes"] = attr_dict
    except Exception:
        pass

    return info if info else None


def dump_tree_nested(max_depth=30):
    """Dump desktop as nested JSON tree with children arrays."""
    Atspi.init()
    desktop = Atspi.get_desktop(0)

    def walk(node, depth=0):
        if depth > max_depth or not node:
            return None
        try:
            role = node.get_role_name().replace(" ", "-")
            name = node.get_name() or ""
            bounds = get_bounds(node)

            # Skip elements with no bounds (invisible) unless top-level
            if depth > 1 and bounds is None:
                return None

            # Skip empty labels (duplicates inside buttons)
            if role == "label" and not name:
                return None

            result = {
                "role": role,
                "name": name,
            }

            if bounds:
                result["bounds"] = bounds

            # Add states (FOCUSED, SELECTED, etc.)
            states = get_states(node)
            if states:
                result["states"] = states

            # Add window info for frame nodes (useful for xdotool)
            if role == "frame":
                window_info = get_window_info(node)
                if window_info:
                    result["window"] = window_info

            # Recursively process children
            children = []
            for i in range(node.get_child_count()):
                child = walk(node.get_child_at_index(i), depth + 1)
                if child:
                    children.append(child)

            if children:
                result["children"] = children

            return result
        except Exception:
            return None

    return walk(desktop)


def dump_tree_aria(max_depth=30):
    """Dump desktop as ARIA-style indented tree."""
    Atspi.init()
    desktop = Atspi.get_desktop(0)
    lines = []

    def format_bounds(bounds):
        if not bounds:
            return ""
        return f"@({bounds['x']},{bounds['y']} {bounds['width']}x{bounds['height']})"

    def format_states(states):
        if not states:
            return ""
        return f"[{','.join(states)}]"

    def walk(node, depth=0):
        if depth > max_depth or not node:
            return
        try:
            role = node.get_role_name().replace(" ", "-")
            name = node.get_name() or ""
            bounds = get_bounds(node)
            states = get_states(node)

            # Skip elements with no bounds unless top-level
            if depth > 1 and bounds is None:
                pass  # Still walk children
            elif role == "label" and not name:
                pass  # Skip empty labels
            else:
                indent = "  " * depth
                bounds_str = format_bounds(bounds)
                states_str = format_states(states)
                if name:
                    lines.append(f"{indent}- {role} \"{name}\" {states_str} {bounds_str}".rstrip())
                else:
                    lines.append(f"{indent}- {role} {states_str} {bounds_str}".rstrip())

            for i in range(node.get_child_count()):
                walk(node.get_child_at_index(i), depth + 1)
        except Exception:
            return

    walk(desktop)
    return "\n".join(lines)


def main():
    parser = argparse.ArgumentParser(
        description="Dump AT-SPI accessibility tree"
    )
    parser.add_argument(
        "--format",
        choices=["json", "aria"],
        default="json",
        help="Output format: json (nested tree) or aria (human-readable)"
    )
    parser.add_argument(
        "--max-depth",
        type=int,
        default=30,
        help="Maximum tree depth (default: 30)"
    )
    args = parser.parse_args()

    if args.format == "aria":
        print(dump_tree_aria(args.max_depth))
    else:
        tree = dump_tree_nested(args.max_depth)
        print(json.dumps(tree, ensure_ascii=False))


if __name__ == "__main__":
    main()

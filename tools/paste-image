#!/bin/bash
# Paste an image file via clipboard
# Usage: paste-image <file-path> [mime-type]

set -euo pipefail

if [ -z "${1:-}" ]; then
  echo "Usage: paste-image <file-path> [mime-type]" >&2
  exit 1
fi

FILE="$1"
MIME="${2:-image/png}"

if [ ! -f "$FILE" ]; then
  echo "File not found: $FILE" >&2
  exit 1
fi

# Copy image to clipboard (backgrounded ? xclip blocks until
# the selection is consumed, so it must run in parallel with the paste)
xclip -selection clipboard -t "$MIME" -i < "$FILE" >/dev/null 2>&1 &
sleep 0.1

# Paste using Ctrl+V (consumes the clipboard, letting xclip exit)
xdotool key ctrl+v

# Small delay after paste
sleep 0.1

echo "pasted: $FILE ($MIME)"

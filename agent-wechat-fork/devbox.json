{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "nodejs_22",
    "pnpm",
    "colima",
    "direnv@latest",
    "rustup",
    "cargo-watch",
    "sqlcipher"
  ],
  "shell": {
    "init_hook": [
      "export DOCKER_HOST=unix://$HOME/.colima/default/docker.sock",
      "if ! rustup show active-toolchain &>/dev/null; then rustup default stable &>/dev/null; fi",
      "export PATH=\"$HOME/.cargo/bin:$PATH\""
    ],
    "scripts": {
      "colima:start": [
        "colima start"
      ],
      "colima:stop": [
        "colima stop"
      ],
      "test": [
        "echo \"Error: no test specified\" && exit 1"
      ]
    }
  }
}

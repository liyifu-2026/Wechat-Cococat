#!/bin/bash
# Scroll up or down
# Usage: scroll <direction> [amount]
#   direction: up or down
#   amount: number of scroll clicks (default: 3)

set -euo pipefail

if [ -z "${1:-}" ]; then
  echo "Usage: scroll <up|down> [amount]" >&2
  exit 1
fi

DIRECTION="$1"
AMOUNT="${2:-3}"

# Button 4 = scroll up, Button 5 = scroll down
if [ "$DIRECTION" = "up" ]; then
  xdotool click --repeat "$AMOUNT" 4
  echo "scrolled up $AMOUNT times"
elif [ "$DIRECTION" = "down" ]; then
  xdotool click --repeat "$AMOUNT" 5
  echo "scrolled down $AMOUNT times"
else
  echo "Invalid direction: $DIRECTION (use 'up' or 'down')" >&2
  exit 1
fi

{
  "name": "agent-wechat",
  "version": "0.1.0",
  "description": "WeChat automation via deterministic FSM",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:watch": "turbo watch build",
    "typecheck": "turbo run typecheck",
    "download:wechat": "bash scripts/download-wechat.sh",
    "build:image": "bash scripts/build-images-local.sh",
    "build:image:arm64": "bash scripts/build-images-local.sh --arch arm64",
    "build:image:amd64": "bash scripts/build-images-local.sh --arch amd64",
    "build:image:all": "bash scripts/build-images-local.sh --arch both",
    "cli": "node packages/cli/dist/cli.js",
    "db": "docker cp agent-wechat:/data/agent.db /tmp/agent.db && docker cp agent-wechat:/data/agent.db-wal /tmp/agent.db-wal 2>/dev/null; docker cp agent-wechat:/data/agent.db-shm /tmp/agent.db-shm 2>/dev/null; sqlite3 -header -column /tmp/agent.db",
    "dev": "bash scripts/dev.sh",
    "dev:watch": "bash scripts/dev-watch.sh",
    "dev:deploy": "bash scripts/dev-deploy.sh",
    "dev:check": "cd packages/agent-server-rust && cargo watch -x check",
    "generate-types": "bash scripts/generate-types.sh",
    "gateway": "pnpm --filter @agent-wechat/wechaty-gateway exec -- node --import tsx src/main.ts",
    "gateway:test": "pnpm --filter @agent-wechat/wechaty-gateway exec -- node --import tsx scripts/test-gateway.ts",
    "gateway:test:remote": "pnpm --filter @agent-wechat/wechaty-gateway exec -- node --import tsx scripts/test-gateway-remote.ts",
    "release": "pnpm build && pnpm changeset publish",
    "version-packages": "pnpm changeset version && bash scripts/sync-cargo-version.sh && pnpm install --lockfile-only"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "turbo": "^2.4.4",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.4"
}

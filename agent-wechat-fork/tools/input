#!/bin/bash
# Type text using clipboard paste (Unicode-safe)
# This works for CJK characters, emoji, and any Unicode text
# Usage: input "<text>"

set -euo pipefail

if [ -z "${1:-}" ]; then
  echo "Usage: input \"<text>\"" >&2
  exit 1
fi

TEXT="$1"

# Copy to clipboard using xclip (backgrounded ? xclip blocks until
# the selection is consumed, so it must run in parallel with the paste)
echo -n "$TEXT" | xclip -selection clipboard >/dev/null 2>&1 &
sleep 0.1

# Paste using Ctrl+V (consumes the clipboard, letting xclip exit)
xdotool key ctrl+v

# Small delay after paste
sleep 0.05

echo "typed: $TEXT"

#!/bin/bash
# Take a screenshot of the WeChat window and save to a temp file
# Usage: screenshot [--file <path>]
#   --file: Save to specific path instead of temp file
# Returns: Path to the screenshot file (use readFile tool to view it)

set -euo pipefail

OUTPUT_FILE=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --file)
      OUTPUT_FILE="$2"
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

# Generate temp file path if not specified
if [ -z "$OUTPUT_FILE" ]; then
  OUTPUT_FILE="/tmp/screenshot-$(date +%s%N).png"
fi

# Capture the screen
scrot -o "$OUTPUT_FILE"

# Return the path
echo "$OUTPUT_FILE"

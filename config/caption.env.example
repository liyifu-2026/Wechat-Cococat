# Caption LLM（图/音/视频封面客观摘要）
# 可与 tencentdb-memory.env 共用 DeepSeek；图片/语音建议用 MiMo（支持 vision/audio）
# 复制到 ~/.config/cococat/caption.env（Windows: %APPDATA%\CocoCat\caption.env）或在 agent.env 中 source

# WECHAT_CAPTION_ENABLED=false   # 禁用 caption LLM（仅用占位）
# WECHAT_CAPTION_API_KEY=        # 默认 TDAI_LLM_API_KEY → XIAOMI_TOKEN_PLAN_CN_API_KEY
# WECHAT_CAPTION_API_URL=        # 默认 TDAI_LLM_BASE_URL 或小米 API base
# WECHAT_CAPTION_MODEL=          # 默认 TDAI_LLM_MODEL 或 PI_MODEL（MiMo 推荐）

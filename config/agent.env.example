# CocoCat Agent 环境变量
# 复制到 ~/.config/cococat/agent.env，由 cococat-stack / 手动 source 加载
# chmod 600 ~/.config/cococat/agent.env

# ── Driver ──────────────────────────────────────────────────────────
AGENT_WECHAT_URL=http://127.0.0.1:6174
# AGENT_WECHAT_TOKEN=              # 默认读 ~/.config/cococat/token

# ── LLM（pi-ai）────────────────────────────────────────────────────
# PI_PROVIDER=anthropic
# PI_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=
# XIAOMI_TOKEN_PLAN_CN_API_KEY=    # MiMo

# ── 队列（BullMQ + Redis，推荐生产启用）──────────────────────────────
# docker compose up -d redis  或自带 Redis 实例
REDIS_URL=redis://127.0.0.1:6379
# QUEUE_ENABLED=true               # 不设 REDIS_URL 时也可显式 true/false
# QUEUE_CONCURRENCY=4              # inbound worker 并发

# ── 回复节奏 ───────────────────────────────────────────────────────
# WECHAT_REPLY_COOLDOWN_MS=0          # service 默认 0；可被 per-chat style.json 覆盖
# WECHAT_PI_HISTORY_LIMIT=40
# WECHAT_PI_BURST_DELAY_MS=400
# CAPTION_TAIL_WINDOW=10

# ── Unified Gate（私聊客服分流 + 静默）──────────────────────────────
# WECHAT_UNIFIED_GATE_LLM=true        # 默认 true；false 则仅规则层
# WECHAT_THOUGHTFUL_ACK_DELAY_MS=15000
# WECHAT_THOUGHTFUL_ACK_PHRASES=稍等|请等一下|我帮您看一下

# ── Thoughtful 两阶段（可选）────────────────────────────────────────
# WECHAT_THOUGHTFUL_ACK=true         # 或自定义文案，如「我看下」
# WECHAT_THOUGHTFUL_REFLECT=true     # Gather 后 Reflect 自检，GAP 则补调研

# ── 群 @ / Wiki / Memory ───────────────────────────────────────────
# BRIDGE_GROUPS_CONFIG=~/.config/cococat/bridge-groups.json
# BRIDGE_REPLY_WITH_MENTION=none
# WIKI_ENABLED=1
# WIKI_API_URL=http://127.0.0.1:19828
# TDAI_GATEWAY_URL=http://127.0.0.1:8420
# TDAI_MEMORY_ENABLED=true

# ── 可选：合并 caption / memory 子配置 ─────────────────────────────
# source ~/.config/cococat/caption.env
# source ~/.config/cococat/memory.env

# TencentDB Agent Memory — 提炼 LLM（DeepSeek flash）
# 复制到 ~/.config/agent-wechat/tencentdb-memory.env 并 chmod 600
# 勿提交 git

TDAI_LLM_PROVIDER=deepseek
TDAI_LLM_MODEL=deepseek-v4-flash
TDAI_LLM_API_KEY=your-deepseek-api-key
TDAI_LLM_BASE_URL=https://api.deepseek.com/v1

# Gateway 认证（可选，sidecar 启用 TDAI_GATEWAY_API_KEY 时 pi-wechat 也要设）
# TDAI_GATEWAY_API_KEY=
# TDAI_RECALL_TIMEOUT_MS=5000

# 管线参数（可调）
TDAI_EVERY_N_CONVERSATIONS=5
TDAI_PERSONA_TRIGGER_EVERY_N=50

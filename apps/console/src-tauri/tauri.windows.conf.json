{
  "bundle": {
    "targets": ["nsis", "msi"],
    "resources": [
      "pdfium/pdfium.dll",
      "runtime"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": ["English", "SimpChinese"]
      },
      "wix": {
        "language": ["en-US", "zh-CN"]
      }
    }
  }
}
